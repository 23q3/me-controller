{
  "name": "me-controller-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/client/main.ts --outdir=public/assets --target=browser --sourcemap=linked",
    "dev:client": "bun build src/client/main.ts --outdir=public/assets --target=browser --sourcemap=linked --watch",
    "dev:server": "bun run src/server/index.ts",
    "dev": "bun run build && bun run dev:server",
    "start": "bun run build && bun run src/server/index.ts",
    "assets": "bun run scripts/build-assets.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "latest"
  }
}
